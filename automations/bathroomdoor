    platform: state
    entity_id:  binary_sensor.door_bathroom 
    to: 'on'
    for:
      minutes: 10
    platform: state
    entity_id:  binary_sensor.door_bathroom 
    to: 'on'
    for:
      minutes: 30
    platform: state
    entity_id:  binary_sensor.door_bathroom 
    to: 'on'
    for:
      minutes: 50
    platform: state
    entity_id:  binary_sensor.door_bathroom 
